# Force LF line endings for scripts and files that run in Linux/Docker
*.sh        text eol=lf
*.py        text eol=lf
*.pl        text eol=lf
*.rb        text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf
*.mk        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.conf      text eol=lf
*.entitlements text eol=lf
